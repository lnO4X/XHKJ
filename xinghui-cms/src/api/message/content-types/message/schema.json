{
  "kind": "collectionType",
  "collectionName": "messages",
  "info": {
    "singularName": "message",
    "pluralName": "messages",
    "displayName": "Message",
    "description": "用户留言"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "phone": {
      "type": "string",
      "maxLength": 20
    },
    "email": {
      "type": "email",
      "required": true
    },
    "content": {
      "type": "text",
      "required": true
    },
    "isRead": {
      "type": "boolean",
      "default": false
    }
  }
}
