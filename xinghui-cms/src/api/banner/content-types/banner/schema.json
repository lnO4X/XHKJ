{
  "kind": "collectionType",
  "collectionName": "banners",
  "info": {
    "singularName": "banner",
    "pluralName": "banners",
    "displayName": "Banner",
    "description": "首页轮播图"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "subtitle": {
      "type": "string",
      "maxLength": 500
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "linkUrl": {
      "type": "string",
      "maxLength": 500
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "required": true
    }
  }
}
